# ╔══════════════════════════════════════════════╗
# ║  MetoSim Environment Configuration           ║
# ╚══════════════════════════════════════════════╝
# Copy to .env and fill in your values

# ── API Configuration ──
METOSIM_API_URL=http://localhost:8000
METOSIM_API_VERSION=v1

# ── Authentication ──
METOSIM_API_KEY=your-api-key-here
METOSIM_SECRET_KEY=your-jwt-secret-here

# ── Database ──
DATABASE_URL=postgresql+asyncpg://metosim:password@localhost:5432/metosim
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# ── Redis (Task Queue) ──
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Object Storage (S3-compatible) ──
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=metosim-results
S3_REGION=us-east-1
S3_PRESIGNED_URL_EXPIRY=900  # 15 minutes

# ── GPU / Compute ──
MODAL_TOKEN_ID=your-modal-token-id
MODAL_TOKEN_SECRET=your-modal-token-secret
GPU_TYPE=B200
MAX_SIMULATION_TIME=3600  # 1 hour

# ── Observability ──
LOG_LEVEL=INFO
LOG_FORMAT=json
SENTRY_DSN=
PROMETHEUS_PORT=9090

# ── Development ──
DEBUG=false
TESTING=false
